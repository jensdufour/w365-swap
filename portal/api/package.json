{
  "name": "mosaic-api",
  "version": "0.0.0",
  "description": "Azure Functions API backend for the Mosaic catalog service",
  "private": true,
  "main": "dist/functions/*.js",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "clean": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\"",
    "prebuild": "npm run clean",
    "build": "tsc",
    "start": "func start",
    "test": "vitest run"
  },
  "dependencies": {
    "@azure/functions": "^4.5.0",
    "@azure/identity": "^4.5.0",
    "@azure/storage-blob": "^12.31.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  }
}
